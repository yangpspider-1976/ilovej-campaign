{%- comment -%}
  iLoveJ voucher claim form. Self-contained section that owns the form and posts
  directly to the campaign API. Fully self-contained (no external CDN/fonts):
  inline SVG PH flag, static +63 prefix, sized to match the original Forms block.
{%- endcomment -%}

<div class="ij-section page-width">
  <form id="ilovej-form" class="ij-form" novalidate>

    <div class="ij-phone-row">
      <div class="ij-flag" aria-hidden="true">
        <svg class="ij-flag-svg" viewBox="0 0 32 16" width="34" height="17" role="img" aria-label="Philippines">
          <rect width="32" height="8" fill="#0038A8"></rect>
          <rect y="8" width="32" height="8" fill="#CE1126"></rect>
          <polygon points="0,0 0,16 13.86,8" fill="#FFFFFF"></polygon>
          <circle cx="4.6" cy="8" r="1.9" fill="#FCD116"></circle>
          <circle cx="1.9" cy="2" r="0.7" fill="#FCD116"></circle>
          <circle cx="1.9" cy="14" r="0.7" fill="#FCD116"></circle>
          <circle cx="11.2" cy="8" r="0.7" fill="#FCD116"></circle>
        </svg>
      </div>
      <div class="ij-phone-box">
        <span class="ij-phone-label">Phone</span>
        <div class="ij-phone-inputwrap">
          <span class="ij-dial">+63</span>
          <input type="tel" id="ilovej-phone" name="phone"
            inputmode="numeric" maxlength="11" placeholder="912 345 6789" autocomplete="tel" />
        </div>
      </div>
    </div>

    <input type="text" id="ilovej-name" name="name" class="ij-input" placeholder="Name" autocomplete="name" />

    <input type="email" id="ilovej-email" name="email" class="ij-input" placeholder="Email" autocomplete="email" />

    <p class="ij-consent-head">Email Consent.</p>
    <label class="ij-check">
      <input type="checkbox" id="ilovej-consent-sms" />
      <span>I agree to have a consent on my email.</span>
    </label>

    <p class="ij-consent-head">Marketing opt-in (Optional)</p>
    <label class="ij-check">
      <input type="checkbox" id="ilovej-consent-mkt" />
      <span>I agree to receive marketing emails from I LOVE J.</span>
    </label>

    <p class="ij-privacy">
      Your mobile number will be used to issue and deliver your voucher, prevent
      duplicate claims, and track campaign performance. Your information will be
      processed according to our
      <a href="/policies/privacy-policy" target="_blank" rel="noopener">Privacy Policy</a>.
    </p>

    <div id="ilovej-msg" class="ij-msg" role="status" aria-live="polite"></div>

    <button type="submit" id="ilovej-btn" class="ij-btn">Claim My Voucher</button>

    <p class="ij-legal">
      By claiming, you agree to our
      <a href="/policies/terms-of-service" target="_blank" rel="noopener">Terms</a>
      and
      <a href="/policies/privacy-policy" target="_blank" rel="noopener">Privacy Policy</a>.
    </p>
  </form>

  <div id="ilovej-success" class="ij-success" role="status" aria-live="polite">
    <p class="ij-success-title">Success</p>
    <p>Thank you for joining!</p>
    <p>Check your phone message inbox to claim your voucher!</p>
    <p>Note: voucher codes should arrive in your inbox within 24 hours</p>
    <a href="https://ilovej.store/collections/all" class="ij-shop-btn">Shop Now</a>
    <p class="ij-success-support">Didn't get your SMS? Message us and we'll check your voucher status.</p>
  </div>
</div>

<style>
  .ij-section { padding: 0 20px 52px; }
  .ij-form {
    max-width: 446px;
    margin: 0 auto;
    font-family: inherit;
    color: #1a1a1a;
    text-align: left;
  }

  /* Phone row: flag selector + phone box */
  .ij-phone-row { display: flex; gap: 8px; margin-bottom: 14px; }
  .ij-flag {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    border: 1px solid #e3e3e3;
    border-radius: 6px;
    background: #fff;
  }
  .ij-flag-svg { border-radius: 2px; display: block; }
  .ij-phone-box {
    flex: 1;
    border: 1px solid #e3e3e3;
    border-radius: 6px;
    background: #fff;
    padding: 6px 14px;
  }
  .ij-phone-label { display: block; font-size: 12px; color: #9b9b9b; line-height: 1.2; }
  .ij-phone-inputwrap { display: flex; align-items: center; gap: 5px; }
  .ij-dial { font-size: 15px; color: #1a1a1a; }
  .ij-phone-box input {
    flex: 1;
    width: 100%;
    border: none;
    outline: none;
    padding: 0;
    font-size: 15px;
    font-family: inherit;
    color: #1a1a1a;
    background: transparent;
  }

  /* Standard inputs */
  .ij-input {
    width: 100%;
    box-sizing: border-box;
    padding: 11px 14px;
    margin-bottom: 14px;
    border: 1px solid #e3e3e3;
    border-radius: 6px;
    font-size: 15px;
    line-height: 1.3;
    font-family: inherit;
    color: #1a1a1a;
    background: #fff;
  }
  .ij-form input::placeholder { color: #9b9b9b; }
  /* Remove the browser's own focus ring so we don't get a doubled box inside
     the phone field; we draw a single blue border on the wrapper instead. */
  .ij-form input:focus { outline: none; box-shadow: none; }
  .ij-input:focus { border-color: #1878B9; }
  .ij-phone-box:focus-within { border-color: #1878B9; }

  /* Consent */
  .ij-consent-head { font-size: 14px; font-weight: 400; margin: 2px 0 8px; }
  .ij-check {
    display: flex;
    gap: 9px;
    align-items: flex-start;
    font-size: 14px;
    font-weight: 400;
    margin-bottom: 14px;
    cursor: pointer;
    line-height: 1.4;
  }
  .ij-check input { margin: 1px 0 0; flex-shrink: 0; width: 16px; height: 16px; cursor: pointer; }

  /* Button */
  .ij-btn {
    width: 100%;
    padding: 13px;
    background: #1c1c1c;
    color: #fff;
    border: none;
    border-radius: 6px;
    font-size: 15px;
    font-weight: 400;
    font-family: inherit;
    cursor: pointer;
    transition: opacity .15s ease;
  }
  .ij-btn:hover { opacity: .88; }
  .ij-btn:disabled { opacity: .55; cursor: default; }

  .ij-msg {
    display: none;
    padding: 13px;
    border-radius: 6px;
    margin-bottom: 14px;
    font-size: 14px;
    font-weight: 600;
  }

  /* Privacy notice + legal links */
  .ij-privacy {
    font-size: 12px;
    color: #9b9b9b;
    line-height: 1.5;
    margin: 0 0 14px;
  }
  .ij-legal {
    font-size: 12px;
    color: #9b9b9b;
    text-align: center;
    margin: 12px 0 0;
  }
  .ij-privacy a, .ij-legal a { color: #1878B9; text-decoration: underline; }

  /* Success state (shown in place of the form) */
  .ij-success {
    display: none;
    max-width: 446px;
    margin: 0 auto;
    text-align: center;
    font-family: inherit;
    color: #1a1a1a;
  }
  .ij-success p { margin: 0 0 6px; font-size: 15px; line-height: 1.5; }
  .ij-success-title {
    /* Use the theme's heading font so "Success" renders bold like page headings */
    font-family: var(--font-heading-family, inherit);
    font-weight: var(--font-heading-weight, 700);
    font-size: 20px;
    margin-bottom: 12px;
  }
  .ij-shop-btn {
    display: inline-block;
    margin: 18px 0 24px;
    padding: 10px 22px;
    background: #1c1c1c;
    color: #fff;
    border-radius: 6px;
    font-size: 13px;
    text-decoration: none;
    transition: opacity .15s ease;
  }
  .ij-shop-btn:hover { opacity: .88; color: #fff; }
  .ij-success-support { font-size: 12px; color: #9b9b9b; margin-top: 14px; }
</style>

<script>
(function () {
  const API = "https://ilovej-campaign.vercel.app/api/voucher/claim";

  const form    = document.getElementById("ilovej-form");
  const phoneEl = document.getElementById("ilovej-phone");
  const nameEl  = document.getElementById("ilovej-name");
  const emailEl = document.getElementById("ilovej-email");
  const cSms    = document.getElementById("ilovej-consent-sms");
  const cMkt    = document.getElementById("ilovej-consent-mkt");
  const btn     = document.getElementById("ilovej-btn");
  const msg     = document.getElementById("ilovej-msg");
  const success = document.getElementById("ilovej-success");

  function show(html, err) {
    msg.innerHTML = html;
    msg.style.display = "block";
    msg.style.background = err ? "#fdeaea" : "#eaf7ee";
    msg.style.color      = err ? "#E02229" : "#1a7a3a";
    msg.style.border     = err ? "1px solid #f3c2c2" : "1px solid #a9dcb8";
  }

  // The +63 is shown as a fixed prefix; the user types the national number.
  function getPhone() {
    let d = (phoneEl.value || "").replace(/\D/g, "");
    if (d.startsWith("63")) d = d.slice(2);   // in case they paste with 63
    if (d.startsWith("0"))  d = d.slice(1);    // strip a leading 0 (09xx)
    if (!/^9\d{9}$/.test(d)) return null;      // PH mobile: 9XXXXXXXXX
    return "+63" + d;
  }

  function utm(k) { return new URLSearchParams(location.search).get(k) || undefined; }

  form.addEventListener("submit", async function (e) {
    e.preventDefault();

    if (!cSms.checked) { show("Please tick the consent box to continue.", true); return; }

    const phone = getPhone();
    if (!phone) { show("Please enter a valid Philippine mobile number (e.g. 912 345 6789).", true); return; }

    btn.disabled = true;
    btn.textContent = "Processing…";
    msg.style.display = "none";

    try {
      const res  = await fetch(API, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          phone,
          name:  nameEl.value  || undefined,
          email: emailEl.value || undefined,
          campaign_id: "ilovej_meta_test",
          consent_voucher_sms: true,
          consent_marketing: cMkt.checked,
          utm_source:   utm("utm_source")   || "shopify",
          utm_medium:   utm("utm_medium"),
          utm_campaign: utm("utm_campaign"),
        }),
      });
      const data = await res.json();

      if (data.already_claimed) {
        show("This number already has a voucher — check your SMS inbox!", false);
      } else if (!data.success) {
        show(data.error || "Something went wrong. Please try again.", true);
      } else {
        // Success: replace the form with the success message (matches original).
        form.style.display = "none";
        success.style.display = "block";
        success.scrollIntoView({ behavior: "smooth", block: "center" });
      }
    } catch (err) {
      show("Network error. Please check your connection and try again.", true);
    } finally {
      btn.disabled = false;
      btn.textContent = "Claim My Voucher";
    }
  });
})();
</script>

{% schema %}
{
  "name": "iLoveJ Voucher Form",
  "settings": [],
  "presets": [{ "name": "iLoveJ Voucher Form" }]
}
{% endschema %}
