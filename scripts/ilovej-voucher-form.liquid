{%- comment -%}
  iLoveJ voucher claim form. Self-contained section that owns the form and posts
  directly to the campaign API. Styled to match the original Shopify Forms block
  1:1 (flag + "+63" phone field, placeholder-only name/email, two consent
  headings with checkboxes, full-width black button).
{%- endcomment -%}

<div class="ij-section page-width">
  <form id="ilovej-form" class="ij-form" novalidate>

    <div class="ij-phone-row">
      <div class="ij-flag" aria-hidden="true">
        <span class="ij-flag-emoji">🇵🇭</span>
        <span class="ij-caret">▾</span>
      </div>
      <div class="ij-phone-box">
        <span class="ij-phone-label">Phone</span>
        <input type="tel" id="ilovej-phone" name="phone"
          value="+63" autocomplete="tel" inputmode="tel" />
      </div>
    </div>

    <input type="text" id="ilovej-name" name="name" class="ij-input" placeholder="Name" autocomplete="name" />

    <input type="email" id="ilovej-email" name="email" class="ij-input" placeholder="Email" autocomplete="email" />

    <p class="ij-consent-head">Email Consent.</p>
    <label class="ij-check">
      <input type="checkbox" id="ilovej-consent-sms" />
      <span>I agree to have a consent on my email.</span>
    </label>

    <p class="ij-consent-head">Marketing opt-in (Optional)</p>
    <label class="ij-check">
      <input type="checkbox" id="ilovej-consent-mkt" />
      <span>I agree to receive marketing emails from I LOVE J.</span>
    </label>

    <div id="ilovej-msg" class="ij-msg" role="status" aria-live="polite"></div>

    <button type="submit" id="ilovej-btn" class="ij-btn">Claim My Voucher</button>
  </form>
</div>

<style>
  .ij-section { padding: 0 20px 52px; }
  .ij-form {
    max-width: 600px;
    margin: 0 auto;
    font-family: inherit;
    color: #1a1a1a;
    text-align: left;
  }

  /* Phone row: flag selector + phone box, side by side */
  .ij-phone-row { display: flex; gap: 12px; margin-bottom: 16px; }
  .ij-flag {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 78px;
    border: 1px solid #e1e1e1;
    border-radius: 8px;
    background: #fff;
  }
  .ij-flag-emoji { font-size: 20px; line-height: 1; }
  .ij-caret { font-size: 11px; color: #555; }
  .ij-phone-box {
    flex: 1;
    border: 1px solid #e1e1e1;
    border-radius: 8px;
    background: #fff;
    padding: 8px 16px;
  }
  .ij-phone-label { display: block; font-size: 12px; color: #9b9b9b; margin-bottom: 2px; }
  .ij-phone-box input {
    width: 100%;
    border: none;
    outline: none;
    padding: 0;
    font-size: 16px;
    font-family: inherit;
    color: #1a1a1a;
    background: transparent;
  }

  /* Standard inputs */
  .ij-input {
    width: 100%;
    box-sizing: border-box;
    padding: 16px;
    margin-bottom: 16px;
    border: 1px solid #e1e1e1;
    border-radius: 8px;
    font-size: 16px;
    font-family: inherit;
    color: #1a1a1a;
    background: #fff;
  }
  .ij-form input::placeholder { color: #9b9b9b; }
  .ij-form input:focus { outline: none; border-color: #1a1a1a; }
  .ij-phone-box:focus-within { border-color: #1a1a1a; }

  /* Consent */
  .ij-consent-head { font-size: 16px; font-weight: 600; margin: 4px 0 10px; }
  .ij-check {
    display: flex;
    gap: 10px;
    align-items: flex-start;
    font-size: 16px;
    margin-bottom: 18px;
    cursor: pointer;
    line-height: 1.4;
  }
  .ij-check input { margin: 2px 0 0; flex-shrink: 0; width: 18px; height: 18px; cursor: pointer; }

  /* Button */
  .ij-btn {
    width: 100%;
    padding: 17px;
    background: #1c1c1c;
    color: #fff;
    border: none;
    border-radius: 8px;
    font-size: 16px;
    font-weight: 700;
    font-family: inherit;
    cursor: pointer;
    transition: opacity .15s ease;
  }
  .ij-btn:hover { opacity: .88; }
  .ij-btn:disabled { opacity: .55; cursor: default; }

  /* Inline result message */
  .ij-msg {
    display: none;
    padding: 14px;
    border-radius: 8px;
    margin-bottom: 16px;
    font-size: 15px;
    font-weight: 600;
  }
</style>

<script>
(function () {
  const API = "https://ilovej-campaign.vercel.app/api/voucher/claim";

  const form    = document.getElementById("ilovej-form");
  const phoneEl = document.getElementById("ilovej-phone");
  const nameEl  = document.getElementById("ilovej-name");
  const emailEl = document.getElementById("ilovej-email");
  const cSms    = document.getElementById("ilovej-consent-sms");
  const cMkt    = document.getElementById("ilovej-consent-mkt");
  const btn     = document.getElementById("ilovej-btn");
  const msg     = document.getElementById("ilovej-msg");

  // Keep the "+63" prefix from being deleted accidentally.
  phoneEl.addEventListener("focus", function () {
    if (!phoneEl.value) phoneEl.value = "+63";
  });

  function show(html, err) {
    msg.innerHTML = html;
    msg.style.display = "block";
    msg.style.background = err ? "#fdeaea" : "#eaf7ee";
    msg.style.color      = err ? "#E02229" : "#1a7a3a";
    msg.style.border     = err ? "1px solid #f3c2c2" : "1px solid #a9dcb8";
  }

  function normalize(raw) {
    let v = (raw || "").trim().replace(/[\s\-().]/g, "");
    if (/^\+639\d{9}$/.test(v)) return v;
    if (/^\+6309\d{9}$/.test(v)) return "+63" + v.slice(4);   // "+630917..." -> drop the 0
    if (/^09\d{9}$/.test(v))    return "+63" + v.slice(1);
    if (/^639\d{9}$/.test(v))   return "+" + v;
    if (/^9\d{9}$/.test(v))     return "+63" + v;
    return null;
  }

  function utm(k) { return new URLSearchParams(location.search).get(k) || undefined; }

  form.addEventListener("submit", async function (e) {
    e.preventDefault();

    if (!cSms.checked) { show("Please tick the consent box to continue.", true); return; }

    const phone = normalize(phoneEl.value);
    if (!phone) { show("Please enter a valid Philippine mobile number (e.g. 09171234567).", true); return; }

    btn.disabled = true;
    btn.textContent = "Processing…";
    msg.style.display = "none";

    try {
      const res  = await fetch(API, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          phone,
          name:  nameEl.value  || undefined,
          email: emailEl.value || undefined,
          campaign_id: "ilovej_meta_test",
          consent_voucher_sms: true,
          consent_marketing: cMkt.checked,
          utm_source:   utm("utm_source")   || "shopify",
          utm_medium:   utm("utm_medium"),
          utm_campaign: utm("utm_campaign"),
        }),
      });
      const data = await res.json();

      if (data.already_claimed) {
        show("This number already has a voucher — check your SMS inbox!", false);
      } else if (!data.success) {
        show(data.error || "Something went wrong. Please try again.", true);
      } else {
        show(data.sms_sent
          ? "🎉 You got <strong>" + data.discount_tier + "% OFF</strong>! Your voucher code was sent to your mobile via SMS."
          : "Voucher claimed! If you don't receive an SMS within a few minutes, please contact support.",
          false);
        form.reset();
      }
    } catch (err) {
      show("Network error. Please check your connection and try again.", true);
    } finally {
      btn.disabled = false;
      btn.textContent = "Claim My Voucher";
    }
  });
})();
</script>

{% schema %}
{
  "name": "iLoveJ Voucher Form",
  "settings": [],
  "presets": [{ "name": "iLoveJ Voucher Form" }]
}
{% endschema %}
